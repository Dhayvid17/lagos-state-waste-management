{
  "name": "lagos-state-waste-management-backend",
  "version": "1.0.0",
  "description": "Lagos Waste Management Backend - NestJS Monorepo",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:auth": "cross-env NODE_ENV=dev nest start auth-service",
    "start:user": "cross-env NODE_ENV=dev nest start user-service",
    "start:report": "cross-env NODE_ENV=dev nest start report-service",
    "start:media": "cross-env NODE_ENV=dev nest start media-service",
    "start:notification": "cross-env NODE_ENV=dev nest start notification-service",
    "start:payment": "cross-env NODE_ENV=dev nest start payment-service",
    "start:auth:dev": "cross-env NODE_ENV=dev nest start auth-service --watch",
    "start:user:dev": "cross-env NODE_ENV=dev nest start user-service --watch",
    "start:report:dev": "cross-env NODE_ENV=dev nest start report-service --watch",
    "start:media:dev": "cross-env NODE_ENV=dev nest start media-service --watch",
    "start:notification:dev": "cross-env NODE_ENV=dev nest start notification-service --watch",
    "start:payment:dev": "cross-env NODE_ENV=dev nest start payment-service --watch",
    "start:auth:debug": "cross-env NODE_ENV=dev nest start auth-service --debug --watch",
    "start:user:debug": "cross-env NODE_ENV=dev nest start user-service --debug --watch",
    "start:report:debug": "cross-env NODE_ENV=dev nest start report-service --debug --watch",
    "start:media:debug": "cross-env NODE_ENV=dev nest start media-service --debug --watch",
    "start:notification:debug": "cross-env NODE_ENV=dev nest start notification-service --debug --watch",
    "start:payment:debug": "cross-env NODE_ENV=dev nest start payment-service --debug --watch",
    "start:auth:prod": "cross-env NODE_ENV=prod node dist/apps/auth-service/main",
    "start:user:prod": "cross-env NODE_ENV=prod node dist/apps/user-service/main",
    "start:report:prod": "cross-env NODE_ENV=prod node dist/apps/report-service/main",
    "start:media:prod": "cross-env NODE_ENV=prod node dist/apps/media-service/main",
    "start:notification:prod": "cross-env NODE_ENV=prod node dist/apps/notification-service/main",
    "start:payment:prod": "cross-env NODE_ENV=prod node dist/apps/payment-service/main",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "cross-env NODE_ENV=dev ts-node prisma/seed.ts",
    "prisma:reset": "prisma migrate reset",
    "infra:up": "docker-compose --env-file ../.env.dev up postgres mongodb redis nats minio -d",
    "infra:down": "docker-compose --env-file ../.env.dev down",
    "infra:logs": "docker-compose --env-file ../.env.dev logs -f",
    "infra:status": "docker-compose --env-file ../.env.dev ps",
    "docker:dev": "docker-compose --env-file ../.env.dev up --build",
    "docker:dev:detach": "docker-compose --env-file ../.env.dev up --build -d",
    "docker:dev:down": "docker-compose --env-file ../.env.dev down",
    "docker:dev:logs": "docker-compose --env-file ../.env.dev logs -f",
    "docker:dev:logs:auth": "docker-compose --env-file ../.env.dev logs -f auth-service",
    "docker:dev:logs:user": "docker-compose --env-file ../.env.dev logs -f user-service",
    "docker:dev:logs:report": "docker-compose --env-file ../.env.dev logs -f report-service",
    "docker:dev:logs:media": "docker-compose --env-file ../.env.dev logs -f media-service",
    "docker:dev:logs:notification": "docker-compose --env-file ../.env.dev logs -f notification-service",
    "docker:dev:logs:payment": "docker-compose --env-file ../.env.dev logs -f payment-service",
    "docker:dev:migrate": "docker-compose --env-file ../.env.dev exec auth-service npx prisma migrate dev",
    "docker:dev:push": "docker-compose --env-file ../.env.dev exec auth-service npx prisma db push",
    "docker:dev:studio": "docker-compose --env-file ../.env.dev exec auth-service npx prisma studio",
    "docker:prod": "docker-compose --env-file ../.env.prod up --build -d",
    "docker:prod:down": "docker-compose --env-file ../.env.prod down",
    "docker:prod:logs": "docker-compose --env-file ../.env.prod logs -f",
    "docker:prod:migrate": "docker-compose --env-file ../.env.prod exec auth-service npx prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "bcrypt": "^5.1.0",
    "bull": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.0",
    "ioredis": "^5.10.1",
    "minio": "^7.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "nats": "^2.0.0",
    "nest-winston": "^1.9.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@app/shared/(.*)": "<rootDir>/libs/shared/src/$1",
      "@app/shared": "<rootDir>/libs/shared/src"
    },
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
